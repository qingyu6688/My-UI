{
  "name": "my-ui-workspace",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vue-tsc -p tsconfig.build.json --noEmit && vite build --mode lib",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "docs:dev": "vitepress dev docs --host 0.0.0.0",
    "docs:build": "vitepress build docs",
    "format": "prettier --write ."
  },
  "workspaces": [
    "packages/*"
  ],
  "dependencies": {
    "vue": "3.5.16"
  },
  "devDependencies": {
    "@eslint/js": "9.28.0",
    "@types/node": "22.15.29",
    "@vitejs/plugin-vue": "5.2.4",
    "@vitest/coverage-v8": "3.2.1",
    "@vue/test-utils": "2.4.6",
    "eslint": "9.28.0",
    "eslint-plugin-vue": "10.1.0",
    "jsdom": "26.1.0",
    "prettier": "3.5.3",
    "sass": "1.89.1",
    "typescript": "5.8.3",
    "typescript-eslint": "8.33.1",
    "vite": "6.3.5",
    "vitepress": "1.6.3",
    "vitest": "3.2.1",
    "vue-tsc": "2.2.10"
  }
}
