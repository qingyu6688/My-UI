{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client", "vitest/globals", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@my-ui/*": ["packages/*"]
    },
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "packages/**/*.ts",
    "packages/**/*.vue",
    "docs/**/*.ts",
    "docs/**/*.vue",
    "tests/**/*.ts",
    "vite.config.ts",
    "vitest.config.ts",
    "eslint.config.mjs"
  ],
  "references": []
}
